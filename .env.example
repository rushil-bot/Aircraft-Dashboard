# ============================================================
# Aircraft Dashboard — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# PostgreSQL
POSTGRES_USER=aircraft
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=aircraft_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Agent service hostnames (optional — defaults work inside Docker)
# Override these only when running services outside of docker-compose
DELAY_PREDICTOR_HOST=delay-predictor
NL_QUERY_HOST=nl-query
ROUTE_RECOMMENDER_HOST=route-recommender
